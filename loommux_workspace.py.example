"""Optional loommux workspace configuration.

Place a copy of this file named ``loommux_workspace.py`` in the directory
where the MCP server is launched, or in one of its parent directories.  The
server passes its process cwd to these functions.  Return any directory you
want the persistent IPython kernel to use.
"""

from pathlib import Path


def resolve_workspace(launch_cwd: Path) -> Path:
    # Default: run code in the directory from which the MCP server was started.
    return launch_cwd


# Usually omitted: loommux uses the same interpreter that launched the server.
# A relative value is resolved from the selected workspace.
# PYTHON = ".venv/bin/python"


